NODE_ENV=development
PORT=3000
PUBLIC_BASE_URL=http://127.0.0.1:3000
POC_MAX_SESSION_SECONDS=480
PROMPT_VERSION=studio-aurora-local-v1
LOG_LEVEL=info
AGENT_MODE=local

# Optional: full path to python.exe if Windows PATH/py launcher is broken
# EDGE_TTS_PYTHON=C:\Users\Elitebook\AppData\Local\Programs\Python\Python312\python.exe

# Neon PostgreSQL connection string. Leave empty locally to use in-memory demo storage.
# Render production should set this from Neon.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/prague_ai_voice?sslmode=require

# Required in production for admin editor, bookings list, CSV export, backup and demo reset
ADMIN_PASSWORD=change-this-admin-password

# Optional SMTP email confirmation. Leave empty to keep bookings working without email.
# For Gmail use an App Password, not the normal account password.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Prague AI Voice <no-reply@example.com>"
BUSINESS_OWNER_EMAIL=
